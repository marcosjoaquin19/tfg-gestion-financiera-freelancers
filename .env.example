# Plantilla de variables de entorno.
# Copiar a .env y completar con valores reales. El archivo .env NUNCA se
# versiona (está en .gitignore): contiene credenciales.

# Base de datos PostgreSQL
POSTGRES_USER=tu_usuario
POSTGRES_PASSWORD=tu_password_seguro
POSTGRES_DB=tfg_freelancers
DATABASE_URL=postgresql://tu_usuario:tu_password_seguro@db:5432/tfg_freelancers

# JWT
# Generar SECRET_KEY con: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=generar_una_clave_aleatoria_y_pegarla_aca
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Groq — solo se usa para el resumen financiero y las recomendaciones.
# Si la clave falta, esos módulos degradan a un fallback local determinístico.
# La clasificación de gastos NO usa Groq (corre 100% con el modelo ML local).
GROQ_API_KEY=tu_api_key_de_groq
GROQ_MODEL=llama-3.3-70b-versatile
